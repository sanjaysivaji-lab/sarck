`,DC=le.button`
  --gradient-size: 75px;
  --gradient-offset: calc(var(--gradient-size) / -2.5);
  --animation-duration: 1s;
  --button-color: #744bc4;

  min-width: 150px;
  height: 50px;
  padding: 3px;
  font-weight: bold;
  border: none;
  border-radius: 25px;
  background: var(--button-color);
  position: relative;
  cursor: pointer;
  transition: transform 0.2s ease-in-out;
  filter: drop-shadow(0 2px 7.5px rgba(0, 0, 0, 0.25));
  overflow: hidden;
  isolation: isolate;

  &::before {
    content: '';
    position: absolute;
    background: radial-gradient(#fff, var(--button-color));
    z-index: 1;
    width: var(--gradient-size);
    height: var(--gradient-size);
    border-radius: 50%;
    left: var(--gradient-offset);
    top: var(--gradient-offset);
    opacity: 0;
    transition: opacity 0.15s ease-in-out;
  }

  &:hover {
    transform: scale(1.1);
  }

  &:hover::before {
    opacity: 1;
    animation: ${FL} var(--animation-duration) linear forwards;
  }
`,BC=le.div`
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  padding: 0 20px;
