  0% {
    opacity: 1;
  }
  38% {
    left: calc(100% - (var(--gradient-size) + var(--gradient-offset)));
    top: var(--gradient-offset);
  }
  50% {
    left: calc(100% - (var(--gradient-size) + var(--gradient-offset)));
    top: calc(100% - var(--gradient-size) - var(--gradient-offset));
  }
  70% {
    opacity: 0.5;
  }
  77% {
    opacity: 0.3;
  }
  88% {
    left: var(--gradient-offset);
    top: calc(100% - var(--gradient-size) - var(--gradient-offset));    
